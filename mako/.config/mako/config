# Global Configuration
font=JetBrainsMono Nerd Font 12
background-color=#282828f2
text-color=#ebdbb2ff
border-size=2
border-radius=8
margin=15,15,15,15
padding=12
width=350
default-timeout=5000

# Low urgency notifications (Subtle gray border)
[urgency=low]
border-color=#a89984ff

# Normal urgency notifications (Gruvbox Yellow border)
[urgency=normal]
border-color=#fabd2fff

# High urgency / Critical notifications (Gruvbox Red border, stays until clicked)
[urgency=high]
border-color=#cc241dff
default-timeout=0
